<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>⚠️ Card-Pro (Admin Account) Balance Alert</title>
    <style>
      body {
        font-family: Arial, Helvetica, sans-serif;
        color: #222;
        margin: 0;
        padding: 0;
      }
      h1,
      h2 {
        color: #d9534f;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0;
      }
      th,
      td {
        padding: 8px 12px;
        border: 1px solid #ddd;
        text-align: left;
        font-size: 14px;
      }
      th {
        background: #f5f5f5;
      }
      tr.low-balance {
        background: #fff4f4;
      }
      @media only screen and (max-width: 620px) {
        table,
        th,
        td {
          font-size: 12px;
        }
      }
    </style>
  </head>
  <body>
    <h1>⚠️ Card-Pro (Admin Account) Balance Alert</h1>
    <h2>Action required: Card-Pro (Admin Account) balance is below the threshold</h2>
    <p>The following balances are below <strong>{{threshold}} USD</strong>:</p>

    <table>
      <thead>
        <tr>
          <th>Currency</th>
          <th>Balance</th>
        </tr>
      </thead>
      <tbody>
        {{#each balances}}
          <tr class='low-balance'>
            <td>{{currency}}</td>
            <td>{{total}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <p>Please top up the Card-Pro (Admin Account) as soon as possible.</p>
  </body>
</html>